{
  "name": "bussiness",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "dev:webpack": "next dev --webpack",
    "clean:next": "node -e \"try { require('fs').rmSync('.next', { recursive: true, force: true }); } catch (e) { if (e.code !== 'ENOENT') throw e; }\"",
    "dev:clean": "npm run clean:next && npm run dev",
    "dev:webpack:clean": "npm run clean:next && npm run dev:webpack",
    "build": "prisma generate && next build",
    "build:with-migrate": "prisma migrate deploy && prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "verify": "npm run lint && npm run build",
    "verify:b1": "tsx scripts/verify-b1-technical.ts",
    "test:preview-match": "tsx --test lib/admin/price-updates/preview-match.test.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "db:migrate": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed-storefront.ts",
    "db:setup": "npm run prisma:generate && npm run prisma:migrate:deploy && npm run prisma:seed",
    "admin:ensure": "tsx scripts/ensure-admin-user.ts",
    "catalog:expand": "tsx scripts/import-expanded-configurator-catalog.ts",
    "catalog:pilot": "tsx scripts/import-pilot-pc-components.ts",
    "catalog:bootstrap-pilot-categories": "tsx scripts/bootstrap-pilot-categories.ts",
    "catalog:import:phase1-mini": "tsx scripts/import-phase1-mini-batch.ts",
    "catalog:safe-wipe": "tsx scripts/catalog-safe-wipe.ts",
    "preview:live-sample": "tsx scripts/preview-live-phase1-sample.ts",
    "data:patch-price-tracking": "tsx scripts/patch-price-tracking-metadata.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "bcryptjs": "^3.0.3",
    "pg": "^8.14.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "next-auth": "^4.24.13",
    "next-intl": "^4.8.3",
    "prisma": "^7.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "tsx prisma/seed-storefront.ts"
  }
}
