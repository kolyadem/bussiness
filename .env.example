# SQLite by default for local development. Replace with a production datasource when deploying.
DATABASE_URL="file:./prisma/dev.db"

# Used by Auth.js / next-auth for signing sessions and CSRF protection.
AUTH_SECRET="replace-with-a-long-random-secret"

# Legacy alias for deployments that still expect the NextAuth variable name.
# NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# Public application origin. These values are also used for canonical URLs, sitemap and social metadata.
NEXTAUTH_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Storage driver. `local` is active now; `s3`, `r2` and `supabase` are reserved for future adapters.
STORAGE_DRIVER="local"
STORAGE_LOCAL_DIR="uploads/products"

# Optional future external storage placeholders.
# STORAGE_PUBLIC_BASE_URL="https://cdn.example.com"
# S3_BUCKET=""
# S3_REGION=""
# S3_ENDPOINT=""
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""

# Internal import scheduler endpoint protection. Required only if you want cron-driven imports.
IMPORT_SCHEDULER_SECRET="replace-with-a-long-random-secret"

# Optional import alert webhook integration.
# IMPORT_ALERT_WEBHOOK_URL="https://example.com/api/import-alerts"
# IMPORT_ALERT_WEBHOOK_SECRET="replace-with-a-long-random-secret"

# Optional Telegram notifications for new build requests.
# TELEGRAM_BOT_TOKEN=""
# TELEGRAM_BUILD_REQUEST_CHAT_ID=""
