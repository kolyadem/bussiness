# PostgreSQL (Neon, local Docker, etc.). Required for Prisma CLI, Next.js, and seeds.
# Neon (Vercel integration): paste the pooled connection string from the Neon dashboard.
# Example: postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/lumina"
# After changing DB or fresh clone: `npx prisma migrate deploy` (creates SiteSettings and all tables in prisma/migrations).

# Used by Auth.js / next-auth for signing sessions and CSRF protection.
AUTH_SECRET="replace-with-a-long-random-secret"

# Legacy alias for deployments that still expect the NextAuth variable name.
# NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# Public application origin. Production: https://your-app.vercel.app
NEXTAUTH_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Storage driver. `local` is active now; `s3`, `r2` and `supabase` are reserved for future adapters.
STORAGE_DRIVER="local"
STORAGE_LOCAL_DIR="uploads/products"

# Optional future external storage placeholders.
# STORAGE_PUBLIC_BASE_URL="https://cdn.example.com"
# S3_BUCKET=""
# S3_REGION=""
# S3_ENDPOINT=""
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""

# Internal import scheduler endpoint protection. Required only if you want cron-driven imports.
IMPORT_SCHEDULER_SECRET="replace-with-a-long-random-secret"

# Optional import alert webhook integration.
# IMPORT_ALERT_WEBHOOK_URL="https://example.com/api/import-alerts"
# IMPORT_ALERT_WEBHOOK_SECRET="replace-with-a-long-random-secret"

# Optional Telegram notifications for new build requests.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_BUILD_REQUEST_CHAT_ID=""

# npm run admin:ensure — create/update owner admin (password never hardcoded; set in .env only).
MAIN_ADMIN_PASSWORD="your-secure-password"
MAIN_ADMIN_USERNAME="kolyadem1"
MAIN_ADMIN_EMAIL="kolyadem2@gmail.com"
# MAIN_ADMIN_LOGIN="kolyadem1"
# MAIN_ADMIN_NAME="Admin"
