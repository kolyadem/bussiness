# =============================================================================
# Copy to ".env" and fill in values. Never commit ".env".
# Stack: PostgreSQL + Prisma 7 + Next.js (see docs/vercel-deploy.md).
# =============================================================================

# --- Database (required for Prisma, API, seeds, admin:ensure) ---------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# --- Auth (NextAuth) — required in production --------------------------------
# Generate: openssl rand -base64 32   (or any long random string)
AUTH_SECRET="replace-with-a-long-random-secret"
# Optional legacy alias for the same secret:
# NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# Public origin of the app (no trailing slash)
# Local: http://localhost:3000  |  Vercel: https://your-project.vercel.app
NEXTAUTH_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# --- Storage (admin product images) -----------------------------------------
# Dev: local files under public/ (default).
# Production (Vercel): use Vercel Blob so uploads survive redeploys.
#   STORAGE_DRIVER=vercel-blob
#   BLOB_READ_WRITE_TOKEN=<from Vercel → Project → Storage → Blob, or link store to project>
STORAGE_DRIVER="local"
STORAGE_LOCAL_DIR="uploads/products"
# BLOB_READ_WRITE_TOKEN=""

# --- Imports cron (optional) ------------------------------------------------
# Protects POST /api/internal/imports/schedule — set a strong random string if you use cron.
IMPORT_SCHEDULER_SECRET="replace-with-a-long-random-secret"

# Optional webhook alerts:
# IMPORT_ALERT_WEBHOOK_URL=""
# IMPORT_ALERT_WEBHOOK_SECRET=""

# --- Telegram (optional — build-request notifications) ----------------------
TELEGRAM_BOT_TOKEN=""
TELEGRAM_BUILD_REQUEST_CHAT_ID=""

# --- Owner admin ------------------------------------------------------------
# Password: required for `npm run admin:ensure` (local).
# On Vercel: same vars are read after migrations by `npm run bootstrap:owner` (see vercel.json).
# If MAIN_ADMIN_PASSWORD is unset on Vercel, bootstrap skips (no crash, log explains).
MAIN_ADMIN_PASSWORD="your-secure-password"
MAIN_ADMIN_USERNAME="kolyadem1"
MAIN_ADMIN_EMAIL="kolyadem2@gmail.com"
# MAIN_ADMIN_NAME="Admin"
